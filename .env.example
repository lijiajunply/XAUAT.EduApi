ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL 连接字符串；留空时默认回退到 SQLite(Data.db)
SQL=

# Redis 连接字符串；留空时表示不启用 Redis
REDIS=localhost:6379

SERVICE_NAME=XAUAT.EduApi
SERVICE_INSTANCE_ID=

PROMETHEUS_ENABLED=true
LOGGING_ENABLED=true

ELECTRICITY_SUBSCRIPTION_SCAN_INTERVAL_MINUTES=15
ELECTRICITY_SUBSCRIPTION_NOTIFICATION_COOLDOWN_MINUTES=720
ELECTRICITY_SUBSCRIPTION_BATCH_SIZE=50

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENABLE_SSL=true
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=XAUAT EduApi

TEST_ACCOUNT_ENABLED=false
TEST_ACCOUNT_USERNAME=frontend-test
TEST_ACCOUNT_PASSWORD=frontend-test-password
TEST_ACCOUNT_STUDENT_ID=20239999
TEST_ACCOUNT_COOKIE_MARKER=frontend-test-marker
TEST_ACCOUNT_FIXTURE_PATH=TestFixtures

GITEE_ACCESS_TOKEN=
START=
END=
